# --- LLM provider (swappable) ----------------------------------------
# anthropic | openai_compat   (openai_compat covers OpenAI, DeepSeek, Ollama, vLLM...)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=sk-ant-xxxxx
# Only for openai_compat: the API base, e.g.
#   https://api.openai.com/v1   |   https://api.deepseek.com/v1   |   http://localhost:11434/v1
LLM_BASE_URL=

# --- storage ----------------------------------------------------------
# SQLite is a single local file, auto-created on first run. Nothing to deploy.
DATABASE_URL=sqlite:///tutor.db

# --- scheduler fence (deterministic guardrails) ------------------------
QUIET_HOURS_START=21
QUIET_HOURS_END=8
MAX_PROMPTS_PER_DAY=4
MIN_GAP_HOURS=2

# --- optional channels --------------------------------------------------
TELEGRAM_TOKEN=
