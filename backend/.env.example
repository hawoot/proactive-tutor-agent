# Copy to backend/.env and fill in. Every run mode reads this file.

# --- LLM provider (swappable) -------------------------------------------------
# Pick ONE block below: uncomment its lines, drop in your API key, done.
# (Leave the other blocks commented out.)

# ----- Option 1: OpenCode Zen "Go" -------------------------------------------
#LLM_PROVIDER=openai_compat
#LLM_MODEL=claude-sonnet-4-6
#LLM_API_KEY=
#LLM_BASE_URL=https://opencode.ai/zen/go/v1

# ----- Option 2: OpenRouter --------------------------------------------------
#LLM_PROVIDER=openai_compat
#LLM_MODEL=anthropic/claude-sonnet-4
#LLM_API_KEY=sk-or-xxxxx
#LLM_BASE_URL=https://openrouter.ai/api/v1

# ----- Option 3: OpenAI ------------------------------------------------------
#LLM_PROVIDER=openai_compat
#LLM_MODEL=gpt-4o
#LLM_API_KEY=sk-xxxxx
#LLM_BASE_URL=https://api.openai.com/v1

# ----- Option 4: Anthropic ---------------------------------------------------
#LLM_PROVIDER=anthropic
#LLM_MODEL=claude-sonnet-4-6
#LLM_API_KEY=sk-ant-xxxxx
# LLM_BASE_URL not needed for anthropic.

# Offline dev (no key, canned questions): LLM_PROVIDER=fake

# --- API security ----------------------------------------------------------------
# REQUIRED for any server reachable from the internet. Pick a long random string;
# the mobile app sends it as the X-API-Key header (Settings screen).
#   generate one:  openssl rand -hex 24
API_KEY=

# --- storage ------------------------------------------------------------------------
# SQLite (default): one local file, auto-created, schema auto-migrated on startup.
# Later upgrade: point at Postgres and restart - nothing else changes.
#   DATABASE_URL=postgresql+psycopg://tutor:secret@localhost:5432/tutor
#DATABASE_URL=sqlite:///tutor.db

# --- scheduler -----------------------------------------------------------------------
# embedded = runs inside the API process (default; right for one container).
# off      = API only (use when running `python -m app.scheduler` separately).
SCHEDULER_MODE=embedded
SCHEDULER_POLL_SECONDS=60
MIN_GAP_HOURS=2

# --- per-user defaults (each user can override via PATCH /users/{id}) ------------------
DEFAULT_TIMEZONE=UTC
QUIET_HOURS_START=21
QUIET_HOURS_END=8
MAX_PROMPTS_PER_DAY=4

# --- optional channels --------------------------------------------------------------------
TELEGRAM_TOKEN=
