{
  "expo": {
    "name": "Tutor",
    "slug": "proactive-tutor",
    "version": "2.1.1",
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1c150f"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nidhal.proactivetutor"
    },
    "android": {
      "package": "com.nidhal.proactivetutor",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2b2118"
      }
    },
    "plugins": [
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "3bdd17d3-b6e4-4802-91de-9a02031614fb"
      }
    },
    "owner": "hawoot",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3bdd17d3-b6e4-4802-91de-9a02031614fb"
    }
  }
}
